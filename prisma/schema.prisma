// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  //output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CANDIDATE
  RECRUITER
}

enum ExperienceLevel {
  FRESHER
  JUNIOR
  MID_LEVEL
  SENIOR
  LEAD
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
}

enum ResumeStatus {
  DRAFT
  COMPLETED
  PUBLISHED
  ARCHIVED
}

enum ResumeVisibility {
  PRIVATE
  RECRUITERS_ONLY
  PUBLIC
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  TEMPORARY
  REMOTE
}

enum SkillProficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  TEMPROARY
}

enum WorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFERED
  HIRED
  REJECTED
  WITHDRAW
}

enum RecommendationStatus {
  ACTIVE
  VIEWED
  DISMISSED
}

enum NotificationType {
  SYSTEM
  JOB
  APPLICATION
  RECOMMENDATION
  ALERT
}

enum AuditActionType {
  USER_REGISTERED
  USER_LOGGED_IN
  PROFILE_UPDATED
  RESUME_UPDATED
  JOB_CREATED
  JOB_UPDATED
  JOB_DELETED
  APPLICATION_SUBMITTED
  APPLICATION_STATUS_CHANGED
  RECOMMENDATION_GENERATED
}

// ==============================
// USER
// ==============================

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  role Role

  emailVerified Boolean @default(false)
  image         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  candidate CandidateProfile?
  recruiter RecruiterProfile?

  notifications Notification[]

  auditLogs AuditLog[]
  jobs      Job[]

  @@index([role])
  @@index([deletedAt])
}

// ==============================
// CANDIDATE PROFILE
// ==============================

model CandidateProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  headline String?
  bio      String? @db.Text

  phone   String?
  city    String?
  state   String?
  country String?

  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?

  experienceLevel ExperienceLevel @default(FRESHER)

  resume          Resume?
  educations      Education[]
  experiences     Experience[]
  projects        CandidateProject[]
  certifications  Certification[]
  candidateSkills CandidateSkill[]

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  jobApplications        JobApplication[]
  jobRecommendations     JobRecommendation[]
  candidateIntelligences CandidateIntelligence[]

  @@index([city])
  @@index([experienceLevel])
}

// ==============================
// COMPANY
// ==============================

model Company {
  id String @id @default(cuid())

  name String
  slug String @unique

  website String?
  logo    String?

  description String? @db.Text

  industry String?

  companySize CompanySize?

  city    String?
  state   String?
  country String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  jobs Job[]

  recruiter RecruiterProfile?

  @@index([name])
  @@index([slug])
}

// ==============================
// RECRUITER PROFILE
// ==============================

model RecruiterProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  designation String?

  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ==============================
// SKILL MASTER
// ==============================

model SkillMaster {
  id String @id @default(cuid())

  name String @unique

  category String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  candidateSkills CandidateSkill[]
  jobSkills       JobSkill[]

  @@index([name])
}

// ===================
// Resume
// ===================

model Resume {
  id                 String           @id @default(cuid())
  candidateProfileId String           @unique
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  title              String
  summary            String?          @db.Text
  fileUrl            String?
  fileName           String?
  mimeType           String?
  fileSize           Int?

  extractedText String? @db.Text

  status     ResumeStatus     @default(DRAFT)
  visibility ResumeVisibility @default(PRIVATE)

  parsedAt  DateTime?
  deletedAt DateTime?

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  jobApplications        JobApplication[]
  jobRecommendations     JobRecommendation[]
  candidateIntelligences CandidateIntelligence[]

  @@index([candidateProfileId])
  @@index([status])
  @@index([visibility])
}

// Education

model Education {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  institutionName String
  degree          String
  fieldOfStudy    String?
  grade           String?
  description     String? @db.Text

  startDate           DateTime?
  endDate             DateTime?
  isCurrentlyStudying Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateProfileId])
  @@index([institutionName])
}

//====================
// Experience
//====================

model Experience {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  companyName      String
  jobTitle         String
  employmentType   EmploymentType @default(FULL_TIME)
  location         String?
  description      String?        @db.Text
  responsibilities String?        @db.Text

  startDate DateTime?
  endDate   DateTime?
  isCurrent Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateProfileId])
  @@index([companyName])
  @@index([jobTitle])
}

//============================
// candidate Profile
//=============================

model CandidateProject {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  title        String
  description  String? @db.Text
  technologies String? @db.Text
  githubUrl    String?
  liveUrl      String?

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateProfileId])
  @@index([title])
}

//===============================
// certifications
//===============================

model Certification {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  title         String
  issuer        String
  credentialId  String?
  credentialUrl String?
  issueDate     DateTime?
  expiryDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateProfileId])
  @@index([issuer])
}

//===========================
// Candidate Skill
//===============================

model CandidateSkill {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  skillId String
  skill   SkillMaster @relation(fields: [skillId], references: [id], onDelete: Cascade)

  proficiencyLevel  SkillProficiency @default(INTERMEDIATE)
  yearsOfExperience Float?
  isPrimary         Boolean          @default(false)
  notes             String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateProfileId, skillId])
  @@index([candidateProfileId])
  @@index([skillId])
}

// ==========================
// Job model
// =========================

model Job {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  postedByID String?
  postedBy   User?   @relation(fields: [postedByID], references: [id], onDelete: SetNull)

  slug             String  @unique
  title            String
  description      String  @db.Text
  responsibilities String? @db.Text
  benefits         String? @db.Text

  jobType  JobType
  workMode WorkMode  @default(REMOTE)
  status   JobStatus @default(DRAFT)

  locationCity    String?
  locationState   String?
  locationCountry String?

  experienceLevel         ExperienceLevel?
  requiredExperienceYears Float?

  salaryMin Int?
  salaryMax Int?
  currency  String? @default("INR")

  applicationDeadline DateTime?
  publishedAt         DateTime?
  closedAt            DateTime?
  deletedAt           DateTime?

  skills          JobSkill[]
  applications    JobApplication[]
  recommendations JobRecommendation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([postedByID])
  @@index([status])
  @@index([jobType])
  @@index([workMode])
  @@index([experienceLevel])
  @@index([deletedAt])
}

// =====================================
// Job skill matching
// =======================================

model JobSkill {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  skillId String
  skill   SkillMaster @relation(fields: [skillId], references: [id], onDelete: Cascade)

  required                 Boolean @default(true)
  importance               Int? // 1 to 5
  minimumYearsOfExperience Float?
  notes                    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, skillId])
  @@index([jobId])
  @@index([skillId])
}

// ==============================
// JOB APPLICATION
// ==============================

model JobApplication {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  status ApplicationStatus @default(APPLIED)

  coverLetter    String? @db.Text
  recruiterNotes String? @db.Text

  appliedAt   DateTime  @default(now())
  reviewedAt  DateTime?
  respondedAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateProfileId, jobId])
  @@index([candidateProfileId])
  @@index([jobId])
  @@index([resumeId])
  @@index([status])
  @@index([deletedAt])
}

// ==============================
// JOB RECOMMENDATION
// ==============================

model JobRecommendation {
  id String @id @default(cuid())

  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  matchingScore Float
  matchedSkills String[]
  missingSkills String[]

  reason String?              @db.Text
  status RecommendationStatus @default(ACTIVE)

  generatedAt DateTime  @default(now())
  viewedAt    DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([candidateProfileId, jobId])
  @@index([candidateProfileId])
  @@index([jobId])
  @@index([resumeId])
  @@index([matchingScore])
}

// =============================
// Candidate intelligence profile
// =============================

model CandidateIntelligence {
  id String @id @default(cuid())

  candidateProfileId String           @unique
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  overallScore    Float
  atsScore        Float
  skillScore      Float
  experienceScore Float
  educationScore  Float
  projectScore    Float

  strengths        String[]
  weaknesses       String[]
  skillGaps        String[]
  recommendedRoles String[]

  summary          String? @db.Text
  suggestions      String? @db.Text
  modelVersion     String?
  analysisMetadata Json?

  generatedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([candidateProfileId])
  @@index([resumeId])
  @@index([overallScore])
  @@index([atsScore])
  @@index([deletedAt])
}

// ==============================
// NOTIFICATIONS
// ==============================

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     NotificationType
  title    String
  message  String           @db.Text
  link     String?
  metadata Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isRead])
}

// ==============================
// AUDIT LOGS
// ==============================

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     AuditActionType
  entityType String
  entityId   String?

  description String? @db.Text
  metadata    Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
}
